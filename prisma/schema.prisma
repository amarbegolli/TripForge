generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Trip {
  id          String   @id @default(cuid())
  destination String
  startDate   String
  endDate     String
  interests   String
  status      String   @default("Planning")
  createdAt   DateTime @default(now())
}